# URL of the url-utilities core service (no trailing slash)
CORE_URL=http://localhost:3000

# x-api-key shared with the core for admin endpoints
CORE_API_KEY=

# Optional. Public URL where short links resolve in a browser (no trailing slash).
# In prod: the core's public Ingress host, same as the core's APP_URL.
# Empty = fall back to CORE_URL.
CORE_PUBLIC_URL=

# Port this admin UI listens on
PORT=4000

# pino log level (fatal | error | warn | info | debug | trace)
LOG_LEVEL=info
