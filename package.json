{
  "name": "url-utilities-admin",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Admin UI for the url-utilities URL shortener (homelab Kubernetes)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralton-dev/url_utilities_admin.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^9.1.1",
    "@fastify/view": "^11.1.1",
    "@platformatic/prom-client": "^1.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "ejs": "^5.0.2",
    "fastify": "^5.2.1",
    "fastify-metrics": "^13.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "^6",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  }
}
