{
  "name": "url-utilities-admin",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Admin UI for the url-utilities URL shortener (homelab Kubernetes)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralton-dev/url_utilities_admin.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/view": "^10.0.1",
    "@t3-oss/env-core": "^0.13.11",
    "ejs": "^3.1.10",
    "fastify": "^5.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^20",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "typescript-eslint": "^8.20.0",
    "undici": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
